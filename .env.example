# Database Configuration
# Uncomment and set values for PostgreSQL, or leave as is for SQLite
#DATABASE_URL=postgresql://username:password@host:port/dbname

# Security Keys (Randomly generate these for production!)
#ENCRYPTION_KEY=your_secure_encryption_key_for_sensitive_data
#FLASK_SECRET_KEY=your_secure_flask_secret_key

# PostgreSQL Container Settings (used with docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=subnet_whisperer

# Command Sanitization
# Set to "disabled" to allow shell operators (pipes, redirects, chaining)
# in SSH commands. Destructive commands (rm -rf /, fork bombs, etc.) are
# always blocked regardless of this setting.
# Default: enabled
#COMMAND_SANITIZATION=disabled

# Docker Configuration
#COMPOSE_PROJECT_NAME=subnet-whisperer